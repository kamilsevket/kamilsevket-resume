---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kamil Şevket Demirtaş">
  <main>
    <div class="container">
      <div class="profile">
        <img src="/profile.jpeg" alt="Kamil Şevket Demirtaş" class="avatar" />
        <h1>Kamil Şevket Demirtaş</h1>
        <p class="role">Senior iOS Developer</p>
        <p class="company">Turkish Airlines</p>
      </div>

      <div class="stats">
        <div class="stat">
          <span class="number">7+</span>
          <span class="label">Years</span>
        </div>
        <div class="stat">
          <span class="number">10M+</span>
          <span class="label">Downloads</span>
        </div>
        <div class="stat">
          <span class="number">5M+</span>
          <span class="label">Users</span>
        </div>
      </div>

      <div class="links">
        <a href="mailto:kamilsevket@hotmail.com" class="link-btn">
          <span>✉️</span> Email
        </a>
        <a href="https://linkedin.com/in/kamilsevket" target="_blank" class="link-btn">
          <span>💼</span> LinkedIn
        </a>
        <a href="https://github.com/kamilsevket" target="_blank" class="link-btn">
          <span>🐙</span> GitHub
        </a>
      </div>

      <div class="highlights">
        <p>🍎 WWDC24 Attendee at Apple Park</p>
        <p>🥽 Vision Pro Lab • Munich</p>
        <p>🏆 Google Startup Weekend Winner</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
  }

  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .container {
    background: white;
    border-radius: 2rem;
    padding: 3rem 2.5rem;
    max-width: 400px;
    width: 100%;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .profile {
    margin-bottom: 2rem;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    border: 4px solid #667eea;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.25rem;
  }

  .role {
    font-size: 1rem;
    color: #667eea;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .company {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .stat {
    text-align: center;
  }

  .stat .number {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a2e;
  }

  .stat .label {
    font-size: 0.75rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .link-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: #f3f4f6;
    color: #1a1a2e;
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .link-btn:hover {
    background: #667eea;
    color: white;
    transform: translateY(-2px);
  }

  .highlights {
    text-align: left;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 0.75rem;
  }

  .highlights p {
    font-size: 0.875rem;
    color: #4b5563;
    padding: 0.5rem 0;
  }

  .highlights p:not(:last-child) {
    border-bottom: 1px solid #e5e7eb;
  }

  @media (max-width: 480px) {
    .container {
      padding: 2rem 1.5rem;
    }

    .stats {
      gap: 1.5rem;
    }
  }
</style>
