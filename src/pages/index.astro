---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kamil Şevket Demirtaş">
  <main>
    <div class="container">
      <div class="profile">
        <img src="/profile.jpeg" alt="Kamil Şevket Demirtaş" class="avatar" />
        <h1>Kamil Şevket Demirtaş</h1>
        <p class="role">Senior iOS Developer</p>
        <p class="company">Turkish Airlines</p>
      </div>

      <div class="experience">
        <span class="exp-number">7+</span>
        <span class="exp-label">Years Experience</span>
      </div>

      <div class="links">
        <a href="mailto:kamilsevket@hotmail.com" class="link-btn">
          <span>✉️</span> Email
        </a>
        <a href="https://linkedin.com/in/kamilsevket" target="_blank" class="link-btn">
          <span>💼</span> LinkedIn
        </a>
        <a href="https://github.com/kamilsevket" target="_blank" class="link-btn">
          <span>🐙</span> GitHub
        </a>
      </div>

      <div class="apps">
        <p class="apps-label">Apps I've worked on</p>
        <div class="app-links">
          <a href="https://apps.apple.com/us/app/turkish-airlines-book-flights/id1283414961" target="_blank" class="app-btn">
            Turkish Airlines
          </a>
          <a href="https://apps.apple.com/us/app/rapsodo-mlm2pro/id1659665092" target="_blank" class="app-btn">
            Rapsodo
          </a>
          <a href="https://apps.apple.com/tr/app/talkido/id1538753496" target="_blank" class="app-btn">
            Talkido
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
  }

  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .container {
    background: white;
    border-radius: 2rem;
    padding: 3rem 2.5rem;
    max-width: 400px;
    width: 100%;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .profile {
    margin-bottom: 1.5rem;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    border: 4px solid #667eea;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.25rem;
  }

  .role {
    font-size: 1rem;
    color: #667eea;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .company {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .experience {
    padding: 1.25rem 0;
    margin-bottom: 1.5rem;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .exp-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #667eea;
  }

  .exp-label {
    font-size: 0.8rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .link-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: #f3f4f6;
    color: #1a1a2e;
    text-decoration: none;
    border-radius: 0.75rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .link-btn:hover {
    background: #667eea;
    color: white;
    transform: translateY(-2px);
  }

  .apps {
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .apps-label {
    font-size: 0.75rem;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .app-links {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .app-btn {
    padding: 0.5rem 1rem;
    background: #f9fafb;
    color: #4b5563;
    text-decoration: none;
    border-radius: 2rem;
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.2s ease;
    border: 1px solid #e5e7eb;
  }

  .app-btn:hover {
    background: #667eea;
    color: white;
    border-color: #667eea;
  }

  @media (max-width: 480px) {
    .container {
      padding: 2rem 1.5rem;
    }
  }
</style>
