---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kamil Şevket Demirtaş - Senior iOS Developer">
  <main>
    <section class="hero">
      <div class="avatar">KŞ</div>
      <h1>Kamil Şevket Demirtaş</h1>
      <p class="tagline">Senior iOS Developer</p>
      <p class="location">📍 Izmir, Turkey</p>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/kamilsevket" target="_blank">LinkedIn</a>
        <a href="https://github.com/kamilsevket" target="_blank">GitHub</a>
        <a href="mailto:kamilsevket@hotmail.com">Email</a>
      </div>
    </section>

    <section class="about">
      <h2>About Me</h2>
      <p>
        Over <strong>7 years</strong> of iOS development experience, backed by a <strong>BSc in Software Engineering</strong>, 
        with expertise in Swift, SwiftUI, Objective-C, CocoaPods, and Firebase.
      </p>
      <p>
        Played a key role in the <strong>Turkish Airlines app</strong>, achieving over <strong>10 million downloads</strong>, 
        8 language support, and a <strong>4.8/5 rating</strong> from 339,000 reviews.
      </p>
      <p>
        A product-driven professional, deeply involved in and embracing the products worked on. 
        Developed and published <strong>7 iOS apps</strong> as a solo developer during weekends.
      </p>
    </section>

    <section class="experience">
      <h2>Experience</h2>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-date">05/2023 - Present</div>
          <div class="timeline-content">
            <h3>Senior iOS Developer</h3>
            <p class="company">Turkish Airlines Technology</p>
            <ul>
              <li>Working in Miles&Smiles loyalty department, serving over <strong>5 million members</strong> globally</li>
              <li>Collaborating with cross-functional teams of <strong>50+ people</strong> on Turkish Airlines iOS app</li>
              <li>Refactored <strong>20,000+ lines</strong> of Objective-C to Swift using MVVM architecture</li>
              <li>Implemented <strong>Live Activities</strong>, <strong>Widgets</strong>, and <strong>Watch app</strong> features</li>
              <li>Leveraging Jenkins for CI/CD to streamline development workflow</li>
            </ul>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">03/2021 - 05/2023</div>
          <div class="timeline-content">
            <h3>iOS Developer → Senior iOS Developer</h3>
            <p class="company">Rapsodo Inc.</p>
            <ul>
              <li>Sports analytics company with technologies used by <strong>200,000+ athletes</strong></li>
              <li>Built <strong>MLM2 Pro iOS app</strong> from scratch; promoted after launching 3 major apps</li>
              <li>Managed iOS scrum team of <strong>8 people</strong>, handling task distribution and code reviews</li>
              <li>Rewrote BLE library achieving <strong>21% reduction</strong> in data transmission latency</li>
              <li>Engineered Performance Analytics feature, driving <strong>75.6% increase</strong> in paid subscriptions</li>
              <li>Improved crash-free rate by <strong>12%</strong> using Xcode Instruments</li>
            </ul>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">08/2018 - 03/2021</div>
          <div class="timeline-content">
            <h3>iOS Developer</h3>
            <p class="company">Mental Segment Inc. (Talkido)</p>
            <ul>
              <li>Screen-free interactive learning devices serving <strong>10,000+ children</strong> in 10+ countries</li>
              <li>Built Talkido iOS app from scratch, reaching <strong>5,000+ users</strong> in 3 months</li>
              <li>Implemented CoreBluetooth for device communication and FFMpeg for audio processing</li>
              <li>Created networking layer with Alamofire, CoreData, and Keychain Access</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="skills">
      <h2>Skills</h2>
      <div class="skill-grid">
        <div class="skill-category">
          <h3>Languages</h3>
          <ul>
            <li>Swift</li>
            <li>Objective-C</li>
            <li>SwiftUI</li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>Frameworks</h3>
          <ul>
            <li>UIKit</li>
            <li>CoreBluetooth</li>
            <li>Combine</li>
            <li>AVFoundation</li>
            <li>CoreData</li>
            <li>StoreKit</li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>Architecture</h3>
          <ul>
            <li>MVVM-C</li>
            <li>MVVM</li>
            <li>MVC</li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>Tools</h3>
          <ul>
            <li>Xcode Cloud</li>
            <li>Jenkins</li>
            <li>Bitrise</li>
            <li>Git / JIRA</li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>AI Tools</h3>
          <ul>
            <li>Claude Code</li>
            <li>ChatGPT</li>
            <li>Cursor</li>
            <li>GitHub Copilot</li>
            <li>n8n</li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>Other</h3>
          <ul>
            <li>Firebase</li>
            <li>REST APIs</li>
            <li>SPM / CocoaPods</li>
            <li>AWS S3</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="highlights">
      <h2>Highlights</h2>
      <div class="highlight-grid">
        <div class="highlight-card">
          <div class="highlight-icon">🍎</div>
          <h3>WWDC24</h3>
          <p class="highlight-location">San Francisco, USA</p>
          <p>Attended WWDC 2024 at Apple Park, learned about Swift 6, Apple Intelligence, and iOS 18 updates</p>
        </div>
        <div class="highlight-card">
          <div class="highlight-icon">🥽</div>
          <h3>Vision Pro Lab</h3>
          <p class="highlight-location">Munich, Germany</p>
          <p>Hands-on experience with Apple Vision Pro before release, developed and tested visionOS apps</p>
        </div>
        <div class="highlight-card">
          <div class="highlight-icon">🏆</div>
          <h3>2x Startup Winner</h3>
          <p class="highlight-location">Google Startup Weekend</p>
          <p>Won 1st place at Startup Weekend Izmir (2016) and Food&Tech (2016) powered by Google</p>
        </div>
      </div>
    </section>

    <section class="education">
      <h2>Education</h2>
      <div class="edu-card">
        <h3>BSc Software Engineering</h3>
        <p class="school">Yaşar University, Izmir</p>
        <p class="edu-date">2015 - 2019</p>
        <ul>
          <li>Developed iOS projects at University's Innovation Center, Minerva</li>
          <li>Founded Student Technology Club YUBIT, served as board member</li>
          <li>Internship at Vestel Inc. - Android & embedded systems</li>
        </ul>
      </div>
    </section>

    <section class="contact">
      <h2>Get In Touch</h2>
      <p>Open to discussing new opportunities and collaborations</p>
      <div class="contact-links">
        <a href="mailto:kamilsevket@hotmail.com" class="cta-button">📧 Email Me</a>
        <a href="https://www.linkedin.com/in/kamilsevket" target="_blank" class="cta-button secondary">💼 LinkedIn</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1d4ed8;
    --bg: #0f172a;
    --bg-light: #1e293b;
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --accent: #38bdf8;
    --success: #22c55e;
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  section {
    margin-bottom: 4rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 0;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: bold;
    margin: 0 auto 1.5rem;
    color: white;
  }

  h1 {
    font-size: 2.75rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .location {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-links a {
    color: var(--accent);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--accent);
    border-radius: 0.5rem;
    transition: all 0.3s;
  }

  .social-links a:hover {
    background: var(--accent);
    color: var(--bg);
  }

  h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--text);
    border-bottom: 2px solid var(--primary);
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  .about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .about strong {
    color: var(--accent);
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--primary), var(--accent));
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
  }

  .timeline-date {
    color: var(--accent);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .timeline-content h3 {
    color: var(--text);
    margin-bottom: 0.25rem;
    font-size: 1.2rem;
  }

  .timeline-content .company {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .timeline-content ul {
    list-style: none;
    padding: 0;
  }

  .timeline-content li {
    padding: 0.4rem 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    padding-left: 1.2rem;
    position: relative;
  }

  .timeline-content li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  .timeline-content li strong {
    color: var(--success);
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    background: var(--bg-light);
    padding: 1.25rem;
    border-radius: 1rem;
  }

  .skill-category h3 {
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .skill-category ul {
    list-style: none;
    padding: 0;
  }

  .skill-category li {
    padding: 0.35rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-bottom: 1px solid var(--bg);
  }

  .skill-category li:last-child {
    border-bottom: none;
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .highlight-card {
    background: var(--bg-light);
    padding: 1.5rem;
    border-radius: 1rem;
    text-align: center;
    border: 1px solid transparent;
    transition: all 0.3s;
  }

  .highlight-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
  }

  .highlight-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .highlight-card h3 {
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .highlight-location {
    color: var(--accent);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .highlight-card p:last-child {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .edu-card {
    background: var(--bg-light);
    padding: 1.5rem;
    border-radius: 1rem;
  }

  .edu-card h3 {
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .school {
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .edu-date {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .edu-card ul {
    list-style: none;
    padding: 0;
  }

  .edu-card li {
    padding: 0.4rem 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    padding-left: 1.2rem;
    position: relative;
  }

  .edu-card li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  .contact {
    text-align: center;
    padding: 3rem;
    background: var(--bg-light);
    border-radius: 1rem;
  }

  .contact p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .contact-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
  }

  .cta-button.secondary {
    background: transparent;
    border: 2px solid var(--accent);
    color: var(--accent);
  }

  .cta-button.secondary:hover {
    background: var(--accent);
    color: var(--bg);
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 2rem;
    }
    
    .social-links {
      flex-direction: column;
      align-items: center;
    }
    
    main {
      padding: 1rem;
    }

    .contact-links {
      flex-direction: column;
    }
  }
</style>
